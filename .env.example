# --- Free-tier provider chain (default) ---
# Priority: NIM (free) → Groq → Cerebras → OpenRouter (paid last resort)
LLM_FREE_TIER_CHAIN=true
LLM_PROVIDER=nvidia

NVIDIA_API_KEY=nvapi-your_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# Role model tiers (NIM primary — fallbacks auto-mapped per tier)
# reasoning: product_owner, architect, code_reviewer → Kimi K2 / GLM-5
# coder: devops, backend, frontend, data, ai, tester → Qwen3-Coder-480B
DEFAULT_LLM=deepseek-ai/deepseek-v3.1-671b-instruct
FALLBACK_LLM=moonshotai/kimi-k2.6

# Safety limits for paid OpenRouter fallback
OPENROUTER_FALLBACK_RATIO_LIMIT=0.20
OPENROUTER_DAILY_SPEND_CAP_EUR=10.0

# Debate structure: core debaters (PO, architect, devops) + one-shot consultants
DEBATE_EARLY_EXIT=true
DEBATE_STABLE_ROUNDS_REQUIRED=2
DEBATE_DETERMINISTIC_TRACKER=true

# Build rules
BUILD_ONE_FEATURE_AT_A_TIME=true
BUILD_SKIP_DEBATE_IF_PATTERN_EXISTS=true

NVIDIA_ENABLE_THINKING=false
NVIDIA_MAX_TOKENS=16384
NVIDIA_TEMPERATURE=1
NVIDIA_TOP_P=0.95
NVIDIA_REASONING_BUDGET=4096

LLM_MAX_RETRIES=6
LLM_RETRY_BACKOFF_SECONDS=10
LLM_REQUEST_TIMEOUT_SECONDS=600
MAX_RETRIES_PER_TASK=5
CONTINUE_ON_TASK_FAILURE=true

# Legacy dual-model (used only when LLM_FREE_TIER_CHAIN=false and no per-agent JSON)
DEBATE_DUAL_MODEL=false
DEBATE_PLANNING_MODEL=
DEBATE_IMPLEMENTATION_MODEL=

# Per-agent override (JSON) — takes precedence over free-tier chain
# DEBATE_PER_AGENT_MODELS={"product_owner":"moonshotai/kimi-k2.6","backend_developer":"qwen/qwen3-coder-480b-a35b-instruct"}

# --- Option D: ZenMux ---
# ZENMUX_API_KEY=
# ZENMUX_BASE_URL=https://zenmux.ai/api/v1

# --- Option B: Anthropic / OpenAI ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

PARALLEL_EXECUTION=true
PARALLEL_GIT=true
GIT_PUSH=false
ENFORCE_SCOPE=true
REQUIRE_CONFIRMATION=true

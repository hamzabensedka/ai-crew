# --- Option C: NVIDIA NIM (OpenAI-compatible) ---
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-your_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Primary model — used for analyze/plan/build + implementation agents in debate
DEFAULT_LLM=deepseek-ai/deepseek-v4-flash

# Secondary model — fallback + planning agents in debate
FALLBACK_LLM=moonshotai/kimi-k2.6

# Dual-model debate (ON by default when both models differ)
DEBATE_DUAL_MODEL=true
# Optional overrides (empty = use FALLBACK_LLM / DEFAULT_LLM above)
DEBATE_PLANNING_MODEL=
DEBATE_IMPLEMENTATION_MODEL=

NVIDIA_ENABLE_THINKING=false
NVIDIA_MAX_TOKENS=16384

# Resilience for long remote autopilot runs (retries 504/timeout, skip failed tasks)
LLM_MAX_RETRIES=6
LLM_RETRY_BACKOFF_SECONDS=10
LLM_REQUEST_TIMEOUT_SECONDS=600
MAX_RETRIES_PER_TASK=5
CONTINUE_ON_TASK_FAILURE=true

# Build uses NVIDIA when API keys are set (--simulation for stub mode)
# Use --limit 5 on build to test before running all tasks

# --- Option D: ZenMux (OpenAI-compatible, free tier models) ---
# LLM_PROVIDER=zenmux
# ZENMUX_API_KEY=your_zenmux_api_key
# ZENMUX_BASE_URL=https://zenmux.ai/api/v1
# DEFAULT_LLM=z-ai/glm-5.2-free
# FALLBACK_LLM=moonshotai/kimi-k2.7-code-free

# --- Option B: Anthropic / OpenAI ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

PARALLEL_EXECUTION=true
PARALLEL_GIT=true
GIT_PUSH=false
ENFORCE_SCOPE=true
REQUIRE_CONFIRMATION=true
